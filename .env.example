# AI 分析服务配置（OpenAI 兼容格式）
# 复制此文件为 .env 并填入你的 API Key

# API Key（必填）
AI_API_KEY=sk-your-api-key-here

# API 基础地址（根据你用的服务商填写）
# DeepSeek:    https://api.deepseek.com
# OpenAI:      https://api.openai.com
# Kimi:        https://api.moonshot.cn
# 智谱:        https://open.bigmodel.cn/api/paas
# 通义千问:    https://dashscope.aliyuncs.com/compatible-mode
# 硅基流动:    https://api.siliconflow.cn
AI_BASE_URL=https://api.deepseek.com

# 模型名称
# DeepSeek:    deepseek-chat
# OpenAI:      gpt-4o-mini
# Kimi:        moonshot-v1-8k
# 智谱:        glm-4-flash
# 通义千问:    qwen-turbo
# 硅基流动:    deepseek-ai/DeepSeek-V3
AI_MODEL=deepseek-chat

# Ollama 配置（本地模型，可选）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:2b-q4_K_M
